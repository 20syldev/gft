#compdef gft gfv

# Zsh completion for gft
# Install to /usr/share/zsh/vendor-completions/_gft

_gft() {
    _arguments \
        '1:repository (user/repo):' \
        '2:tag or version range:' \
        '--assets[List release binary assets]' \
        '--detect[Auto-detect OS/arch and suggest assets]' \
        '--get[Download asset matching pattern]:pattern:' \
        '--install[Download, extract and install binary]' \
        '--releases[List all available releases]' \
        '--list[List all available releases]' \
        '--source[Download source archive non-interactively]:format:(zip tar)' \
        '--checksum[Verify download checksum]' \
        '--verify[Verify download checksum]' \
        '--notes[Show release notes]' \
        '--json[Output as JSON]' \
        '--pre[Include pre-releases when resolving latest]' \
        '--prerelease[Include pre-releases when resolving latest]' \
        '--open[Open release page in browser]' \
        '(-q --quiet)'{-q,--quiet}'[Output version only]' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--check-update[Check for newer version]' \
        '--upgrade[Upgrade gft to latest version]' \
        '--no-color[Disable colors]' \
        '--no-cache[Bypass response cache]' \
        '--clear-cache[Clear all cached responses]'
}

_gft "$@"
